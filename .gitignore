# ── Virtual env & bytecode ─────────────────────────────────
.venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ── Secrets ────────────────────────────────────────────────
.env
.env.*
*.key
data/mappings/.key
# never commit user store — create with: uv run confidoc-auth create-user <username>
data/auth/users.json
# never commit encrypted per-user settings
data/auth/user_settings/
# real server config — keep placeholder version in sources.sample.json
data/source_configs/sources.json

# ── PDFs (never commit patient/confidential documents) ─────
*.pdf
*.PDF
!data/demo/*.pdf

# ── All runtime data (persisted on Render's disk, not git) ─
data/input/*
data/extracted/*
data/anonymized/*
data/reviewed/*
data/normalized/*
data/exported/*
data/final/*
data/jobs/*
data/mappings/*
data/prepared_packages/*
data/zone1/*
data/zone2/*
data/audit.jsonl
data/approved_terms.jsonl
!data/**/.gitkeep

# ── Local dev dumps ─────────────────────────────────────────
zshdumps/

# ── Build artefacts ────────────────────────────────────────
dist/
*.egg-info/
.DS_Store

# ----
DEV_SRVR.md
DEV.md